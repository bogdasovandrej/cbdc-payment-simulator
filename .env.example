# Скопируйте в .env и подставьте свои значения

# База данных (для локального запуска без Docker)
DATABASE_URL=postgresql+psycopg2://cbdc:cbdc@localhost:5432/cbdc

# JWT
JWT_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# QR-код
QR_TTL_MINUTES=15

# Mock CBDC API
MOCK_MIN_DELAY_SECONDS=1.0
MOCK_MAX_DELAY_SECONDS=3.0
MOCK_FAIL_PROBABILITY=0.2

# Платёжный провайдер: mock | yookassa
PAYMENT_PROVIDER=mock

# ЮKassa (нужны только при PAYMENT_PROVIDER=yookassa;
# подходит тестовый магазин: shopId + ключ test_...)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:8000/
